import funkin.play.song.Song;
import funkin.save.Save;

class TutorialMikeMarforiMixSong extends Song
{
  public function new()
  {
    super('tutorial',
      {
        variation: 'mike'
      });
  }

  public override function isSongNew(currentDifficulty:String, currentVariation:String):Bool
  {
    if (currentVariation == 'mike') return !Save.instance.hasBeatenSong(this.id, null, this.variation);

    return false;
  }
}
