import funkin.play.song.Song;
import funkin.save.Save;

class TutorialScottMoeMixSong extends Song
{
  public function new()
  {
    super('tutorial',
      {
        variation: 'scott'
      });
  }

  public override function isSongNew(currentDifficulty:String, currentVariation:String):Bool
  {
    if (currentVariation == 'scott') return !Save.instance.hasBeatenSong(this.id, null, this.variation);

    return false;
  }
}
